{
  "_note": "VS Code + GitHub Copilot 專用。matcher 為 run_in_terminal，已驗證與 rtk hook claude 相容。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "run_in_terminal",
        "hooks": [
          {
            "type": "command",
            "osx": "rtk hook claude",
            "linux": "rtk hook claude",
            "windows": "rtk hook claude"
          }
        ]
      }
    ]
  }
}
